pipeline {

    agent any

    options {

        timeout(time: 30, unit: 'MINUTES')

        disableConcurrentBuilds()

        timestamps()

        buildDiscarder(logRotator(numToKeepStr: '20'))

        retry(2)

    }

    parameters {

        choice(
            name: 'BROWSER',
            choices: ['chrome', 'firefox'],
            description: 'Browser'
        )

        booleanParam(
            name: 'HEADLESS',
            defaultValue: false,
            description: 'Run Headless'
        )

    }

    stages {

        stage('Build & Test') {

            steps {

                bat "mvn clean test -Dbrowser=${params.BROWSER} -Dheadless=${params.HEADLESS}"

            }

        }

    }
    // triggers {

    //     pollSCM('* * * * *')
    //     corn('H/5 * * * *'  )

    // }

    post {

        always {

            archiveArtifacts artifacts: 'report.html', fingerprint: true

            publishHTML([
                    allowMissing: false,
                    alwaysLinkToLastBuild: true,
                    keepAll: true,
                    reportDir: '.',
                    reportFiles: 'report.html',
                    reportName: 'Automation Report'
            ])
        }

        success {

            echo 'Automation executed successfully.'
            emailext(

                subject: "Build Success - ${env.JOB_NAME} #${env.BUILD_NUMBER}",

                body: """
                    Build failed.

                    Job: ${env.JOB_NAME}

                    Build: ${env.BUILD_NUMBER}

                    Branch: ${env.BRANCH_NAME}

                    URL: ${env.BUILD_URL}

                """,

                to: "vital121ahhari@gmail.com"

            )

        }

        failure {

            echo 'Automation execution failed.'
            emailext(

                subject: "Build Failed - ${env.JOB_NAME} #${env.BUILD_NUMBER}",

                body: """
                    Build failed.

                    Job: ${env.JOB_NAME}

                    Build: ${env.BUILD_NUMBER}

                    Branch: ${env.BRANCH_NAME}

                    URL: ${env.BUILD_URL}

                """,

                to: "vital121ahhari@gmail.com"

            )

        }

        unstable{
            echo 'Automation execution is unstable.'
        }

        aborted{
            echo 'Automation execution aborted.'
        }

    }

}