pipeline {

    agent any

    stages {

        stage('Branch Information') {
            steps {
                echo "Current Branch : ${env.BRANCH_NAME}"
            }
        }

        stage('Main Branch Tests') {

            when {
                branch 'main'
            }

            steps {

                echo 'Running Selenium Tests on MAIN'

                bat 'mvn clean test'

            }

        }

        stage('Develop Branch') {

            when {
                branch 'develop'
            }

            steps {

                echo 'Running DEVELOP branch'

            }

        }

        stage('Feature Branch') {

            when {
                expression {
                    env.BRANCH_NAME.startsWith("feature/")
                }
            }

            steps {

                echo "Running Feature Branch : ${env.BRANCH_NAME}"

            }

        }

    }

}